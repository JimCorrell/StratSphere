@model StratSphere.Web.Models.ViewModels.Import.SomUploadViewModel
@{ ViewData["Title"] = "Import SOM Results"; Layout = "_Layout"; }

<div style="max-width:560px;margin:2rem auto">
    <div style="margin-bottom:12px">
        <a href="/league/@Model.LeagueAbbreviation" style="font-family:var(--f-sans);font-size:12px;color:var(--ink-3);text-decoration:none;letter-spacing:.04em">
            ← Back to league
        </a>
    </div>

    <div class="card" style="padding:32px 32px 28px">
        <div class="eyebrow" style="margin-bottom:8px">Commissioner · Data Import</div>
        <h1 style="font-family:var(--f-display);font-weight:900;font-size:36px;text-transform:uppercase;letter-spacing:-.01em;line-height:.95;margin:0 0 8px">Import SOM Results</h1>
        <p style="font-family:var(--f-serif);font-size:14px;color:var(--ink-2);margin:0 0 24px;line-height:1.5">
            Upload your Strat-O-Matic league export file to sync game results, standings, and player stats.
        </p>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error" style="margin-bottom:20px">⚠ @TempData["Error"]</div>
        }

        <div class="card" style="padding:16px 20px;margin-bottom:24px;background:color-mix(in srgb,var(--mustard) 10%,transparent);border:1px solid color-mix(in srgb,var(--mustard) 40%,transparent)">
            <div style="font-family:var(--f-display);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--mustard);margin-bottom:6px">Active Season</div>
            <div style="font-family:var(--f-display);font-size:20px;font-weight:800;text-transform:uppercase">@Model.SeasonName</div>
            <div style="font-family:var(--f-sans);font-size:12px;color:var(--ink-3);margin-top:4px">Game results will import into this season.</div>
        </div>

        <form action="/league/@Model.LeagueAbbreviation/import/upload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">SOM League Export File</label>
                <input type="file" name="file" accept=".lzp,.zip"
                       style="display:block;width:100%;font-family:var(--f-sans);font-size:13px;padding:10px 12px;border:1.5px solid var(--rule-strong);background:var(--paper);color:var(--ink)" />
                <div style="font-family:var(--f-sans);font-size:11px;color:var(--ink-3);margin-top:4px">
                    Export from SOM PC Baseball: File → Export → League Archive (.lzp)
                </div>
            </div>

            <button type="submit" class="btn" style="width:100%;justify-content:center;margin-top:8px;font-size:13px;padding:11px">
                Parse Archive
            </button>
        </form>

        <div style="margin-top:28px;padding-top:20px;border-top:1px solid var(--rule)">
            <div style="font-family:var(--f-display);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-3);margin-bottom:10px">What gets imported</div>
            <div style="display:flex;flex-direction:column;gap:6px">
                @foreach (var item in new[] {
                    "Game results (scores + W/L for each completed game)",
                    "Season standings (W, L, PCT, GB, Runs, Splits, Streak)",
                    "Player batting stats (AB, H, HR, RBI, BB, K, SB)",
                    "Player pitching stats (IP, W, L, SV, ER, H, BB, K)"
                })
                {
                    <div style="display:flex;align-items:center;gap:8px;font-family:var(--f-sans);font-size:12px;color:var(--ink-2)">
                        <span style="color:var(--green-field);font-weight:700">✓</span> @item
                    </div>
                }
            </div>
        </div>
    </div>
</div>
