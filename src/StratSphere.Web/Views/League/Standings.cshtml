@{
    ViewData["Title"] = "Standings";
    Layout = "_Layout";
    var leagueName = ViewData["LeagueName"] as string ?? "";
    var abbr       = ViewData["LeagueAbbreviation"] as string ?? "";
}

<div class="card lift-accent" style="margin-bottom:var(--gap);padding:22px 24px">
    <div class="eyebrow">@abbr · Standings</div>
    <h2 style="font-family:var(--f-display);font-weight:900;font-size:36px;text-transform:uppercase;letter-spacing:-.01em;margin:4px 0 0">@leagueName</h2>
</div>

<div style="padding:80px 0;text-align:center">
    <div style="font-family:var(--f-display);font-size:48px;font-weight:900;text-transform:uppercase;letter-spacing:.04em;color:var(--ink-3);line-height:1">
        Standings
    </div>
    <div style="font-family:var(--f-sans);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-3);font-weight:700;margin-top:10px">
        Full standings · Coming soon to your console
    </div>
    <div style="margin-top:28px">
        <a href="/league/@abbr" class="btn ghost" style="text-decoration:none">← Back to Scoreboard</a>
    </div>
</div>
