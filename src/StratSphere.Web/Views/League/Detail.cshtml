@model StratSphere.Web.Models.ViewModels.League.LeagueDetailViewModel
@{ ViewData["Title"] = Model.Name; Layout = "_Layout"; }

@{
    var today     = DateTime.Today;
    var todayFmt  = today.ToString("dddd, MMMM d").ToUpper();
    var abbr      = Model.Abbreviation.ToLower();
    var seasonYear = Model.SelectedSeasonCardYear?.ToString() ?? "—";
}

@* Email confirmation banner *@
@if (!Model.UserEmailConfirmed)
{
    <div style="background:var(--mustard);color:var(--ink);padding:9px 24px;font-family:var(--f-sans);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;display:flex;align-items:center;gap:12px">
        <span>⚠ Email not confirmed —</span>
        <a href="/account/profile" style="color:var(--ink);text-decoration:underline">Confirm to unlock season creation</a>
    </div>
}

@if (TempData["Success"] != null)
{
    <div style="background:var(--green-field);color:#fff;padding:9px 24px;font-family:var(--f-sans);font-size:11px;font-weight:700;letter-spacing:.1em">✓ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div style="background:var(--oxblood);color:#fff;padding:9px 24px;font-family:var(--f-sans);font-size:11px;font-weight:700;letter-spacing:.1em">⚠ @TempData["Error"]</div>
}

@* ── Ticker Hero ──────────────────────────────────────────────────────── *@
<div class="card lift-accent" style="background:var(--paper-2);margin-bottom:var(--gap)">
    <div style="display:grid;grid-template-columns:auto 1fr auto;gap:22px;align-items:center;padding:18px 22px">
        <div style="display:flex;flex-direction:column;gap:4px">
            <span class="eyebrow">@seasonYear · @todayFmt</span>
            <span style="font-family:var(--f-display);font-weight:900;font-size:28px;text-transform:uppercase;line-height:1;letter-spacing:-0.005em">
                Today's Card
            </span>
        </div>
        <div style="display:flex;gap:22px;font-family:var(--f-sans);flex-wrap:nowrap;white-space:nowrap">
            <div>
                <div style="font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);font-weight:700">Teams</div>
                <div style="font-family:var(--f-display);font-size:22px;font-weight:900">@Model.Teams.Count()</div>
            </div>
            <div>
                <div style="font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);font-weight:700">Members</div>
                <div style="font-family:var(--f-display);font-size:22px;font-weight:900">@Model.Members.Count()</div>
            </div>
            <div>
                <div style="font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);font-weight:700">Slate</div>
                <div style="font-family:var(--f-display);font-size:22px;font-weight:900">—</div>
            </div>
            <div>
                <div style="font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);font-weight:700">Season</div>
                <div style="font-family:var(--f-display);font-size:22px;font-weight:900">@seasonYear</div>
            </div>
        </div>
        <div style="display:flex;gap:8px">
            @if (Model.IsCommissioner && Model.Seasons.Any())
            {
                <a href="/league/@abbr/season/create" class="btn sm">+ Season</a>
            }
            @if (Model.IsCommissioner && !Model.Teams.Any())
            {
                <a href="/league/@abbr/team/create" class="btn sm primary">+ Team</a>
            }
        </div>
    </div>
</div>

@* ── Scoreboard ──────────────────────────────────────────────────────── *@
<div style="margin-bottom:var(--gap)">
    <div class="sec-hdr">
        <h2>Scoreboard</h2>
        <span class="sub">Today's slate · Updates each sim tick</span>
    </div>
    <div class="card" style="padding:32px 24px;text-align:center;color:var(--ink-3)">
        <div style="font-family:var(--f-display);font-size:18px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">No games on the card today</div>
        <div style="font-family:var(--f-sans);font-size:12px;letter-spacing:.06em">
            @if (!Model.Seasons.Any())
            {
                if (Model.IsCommissioner)
                {
                    <span>Create a season to generate a schedule. <a href="/league/@abbr/season/create" style="color:var(--accent);font-weight:700">Create season →</a></span>
                }
                else
                {
                    <span>The commissioner hasn't created a season yet.</span>
                }
            }
            else
            {
                <span>Games will appear here once the season is underway.</span>
            }
        </div>
    </div>
</div>

@* ── Standings + Teams ───────────────────────────────────────────────── *@
<div class="col-2" style="margin-bottom:var(--gap)">

    <div>
        <div class="sec-hdr">
            <h2>Standings</h2>
            @if (Model.SelectedSeasonName is not null)
            {
                <span class="sub">@Model.SelectedSeasonName</span>
            }
            <span class="right">
                <a href="/league/@abbr/standings" style="color:var(--accent);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-family:var(--f-sans);font-size:11px">Full Standings →</a>
            </span>
        </div>

        @if (!Model.Seasons.Any())
        {
            <div class="card" style="padding:24px;text-align:center;color:var(--ink-3);font-family:var(--f-sans);font-size:12px">
                No seasons yet.
                @if (Model.IsCommissioner)
                {
                    <a href="/league/@abbr/season/create" style="color:var(--accent);font-weight:700">Create the first season →</a>
                }
            </div>
        }
        else if (!Model.Standings.Any())
        {
            <div class="card" style="padding:24px;text-align:center;color:var(--ink-3);font-family:var(--f-sans);font-size:12px">
                No standings data yet.
                @if (Model.SelectedSeasonCardYear.HasValue)
                {
                    <a href="/league/@abbr/season/@Model.SelectedSeasonCardYear" style="color:var(--accent);font-weight:700;margin-left:4px">View season setup →</a>
                }
            </div>
        }
        else
        {
            <div class="card lift">
                <table class="standings-table">
                    <thead>
                        <tr>
                            <th class="l">Club</th>
                            <th>W</th>
                            <th>L</th>
                            <th>PCT</th>
                            <th>RS</th>
                            <th>RA</th>
                            <th>DIFF</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Standings)
                        {
                            <tr>
                                <td>
                                    <span class="team-cell">
                                        <span class="team-chip" style="width:26px;height:26px;flex:0 0 26px;font-size:13px">@row.Abbreviation[0]</span>
                                        <span class="team-mono" style="font-size:14px">@row.Abbreviation</span>
                                        <span style="font-family:var(--f-sans);font-size:11px;color:var(--ink-3)">@row.TeamName</span>
                                    </span>
                                </td>
                                <td class="num win">@row.Wins</td>
                                <td class="num">@row.Losses</td>
                                <td class="num">@row.WinPct.ToString("F3")</td>
                                <td class="num">@row.RunsScored</td>
                                <td class="num">@row.RunsAllowed</td>
                                <td class="num @(row.RunDiff >= 0 ? "win" : "streak L")">@(row.RunDiff >= 0 ? "+" : "")@row.RunDiff</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div>
        <div class="sec-hdr">
            <h2>Teams</h2>
            <span class="sub">@Model.Teams.Count() clubs</span>
            @if (Model.IsCommissioner)
            {
                <span class="right">
                    <a href="/league/@abbr/team/create" style="color:var(--accent);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-family:var(--f-sans);font-size:11px">+ New Team</a>
                </span>
            }
        </div>

        @if (!Model.Teams.Any())
        {
            <div class="card" style="padding:24px;text-align:center;color:var(--ink-3);font-family:var(--f-sans);font-size:12px">
                @if (Model.IsCommissioner)
                {
                    <span>No teams yet. <a href="/league/@abbr/team/create" style="color:var(--accent);font-weight:700">Create teams →</a></span>
                }
                else
                {
                    <span>No teams yet. Ask the commissioner to create them.</span>
                }
            </div>
        }
        else
        {
            <div class="card lift" style="padding:6px 0">
                @foreach (var team in Model.Teams)
                {
                    var accentBorder = team.IsOwner ? "border-left:3px solid var(--accent)" : "border-left:3px solid transparent";
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px dashed var(--rule);@accentBorder">
                        <div style="display:flex;align-items:center;gap:10px">
                            <span class="team-chip" style="width:30px;height:30px;flex:0 0 30px;font-size:15px">@team.Abbreviation[0]</span>
                            <div>
                                <div style="font-family:var(--f-display);font-weight:700;font-size:14px;text-transform:uppercase;letter-spacing:.03em">@team.City @team.Name</div>
                                <div style="font-family:var(--f-sans);font-size:10.5px;color:var(--ink-3)">@team.Abbreviation</div>
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px">
                            @if (team.IsClaimed)
                            {
                                <span style="font-family:var(--f-sans);font-size:11px;color:var(--ink-3)">@team.ManagerName</span>
                                @if (team.IsOwner)
                                {
                                    <span class="pill accent" style="font-size:9px">Your team</span>
                                }
                            }
                            else if (!Model.HasTeam && Model.SelectedSeasonCardYear.HasValue)
                            {
                                <form action="/league/@abbr/season/@Model.SelectedSeasonCardYear/team/@team.Abbreviation/claim" method="post" style="margin:0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn sm" style="cursor:pointer">Claim</button>
                                </form>
                            }
                            else
                            {
                                <span class="pill" style="font-size:9px;opacity:.5">Unclaimed</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@* ── The Wire + League Pulse ─────────────────────────────────────────── *@
<div class="col-2" style="margin-bottom:var(--gap)">

    <div>
        <div class="sec-hdr">
            <h2>The Wire</h2>
            <span class="sub">Recaps, transactions, league office</span>
        </div>
        <div class="card lift" style="padding:32px 24px;text-align:center;color:var(--ink-3)">
            <div style="font-family:var(--f-display);font-size:16px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">Coming Soon</div>
            <div style="font-family:var(--f-sans);font-size:12px">Game recaps and the transaction wire will appear here once the season is underway.</div>
        </div>
    </div>

    <div>
        <div class="sec-hdr">
            <h2>League Pulse</h2>
            <span class="sub">Stats &amp; members</span>
        </div>

        <div class="card lift" style="margin-bottom:12px">
            <div class="card-hdr">
                <h3>Statistical Leaders</h3>
                <span class="stamp">@seasonYear Season</span>
            </div>
            <div style="padding:20px 16px;text-align:center;color:var(--ink-3);font-family:var(--f-sans);font-size:12px">
                Stats leaders will appear once the season is underway.
            </div>
        </div>

        <div class="card lift">
            <div class="card-hdr">
                <h3>Members</h3>
                <span class="stamp">@Model.Members.Count() total</span>
            </div>
            <div style="padding:6px 0">
                @foreach (var member in Model.Members)
                {
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 14px;border-bottom:1px dashed var(--rule)">
                        <span style="font-family:var(--f-sans);font-size:13px">@member.DisplayName</span>
                        <span style="font-family:var(--f-sans);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:@(member.Role == "Commissioner" ? "var(--mustard)" : "var(--ink-3)")">@member.Role</span>
                    </div>
                }
                @if (Model.IsCommissioner)
                {
                    <div style="padding:10px 14px">
                        <div style="font-family:var(--f-sans);font-size:10.5px;color:var(--ink-3);margin-bottom:3px">Join code:</div>
                        <code style="font-family:var(--f-mono);font-size:12px;font-weight:700;letter-spacing:.08em">@Model.Slug</code>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── Commissioner / Admin controls ───────────────────────────────────── *@
@if (Model.IsCommissioner && Model.AssignableMembers.Any())
{
    <div style="margin-bottom:var(--gap)">
        <div class="sec-hdr"><h2>Commissioner Tools</h2></div>
        <div class="card" style="padding:16px 20px;max-width:420px">
            <div style="font-family:var(--f-sans);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-3);margin-bottom:10px">Transfer Commissioner Role</div>
            <form action="/league/@abbr/assign-commissioner" method="post" style="display:flex;gap:8px;align-items:flex-end">
                @Html.AntiForgeryToken()
                <select name="NewCommissionerId" style="flex:1;padding:8px 10px;border:1.5px solid var(--ink);background:var(--paper);font-family:var(--f-sans);font-size:13px;color:var(--ink)">
                    @foreach (var m in Model.AssignableMembers)
                    {
                        <option value="@m.UserId">@m.DisplayName</option>
                    }
                </select>
                <button type="submit" class="btn sm ghost" style="cursor:pointer"
                        onclick="return confirm('Transfer commissioner role? You will become a regular manager.')">Transfer</button>
            </form>
        </div>
    </div>
}

@if (Model.IsAdmin)
{
    <div style="border-top:1px solid rgba(180,30,30,.3);padding-top:20px;margin-bottom:var(--gap)">
        <div class="sec-hdr"><h2 style="color:var(--oxblood)">Admin Controls</h2></div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
            @if (Model.IsArchived)
            {
                <form action="/league/@abbr/unarchive" method="post" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn ghost" style="cursor:pointer">Restore League</button>
                </form>
            }
            else
            {
                <form action="/league/@abbr/archive" method="post" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn ghost" style="cursor:pointer"
                            onclick="return confirm('Archive this league?')">Archive League</button>
                </form>
            }
            <form action="/league/@abbr/delete" method="post" style="margin:0"
                  onsubmit="return confirm('Permanently delete &quot;@Model.Name&quot; and ALL its data? This cannot be undone.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn danger" style="cursor:pointer">Delete League</button>
            </form>
        </div>
    </div>
}

@* ── Seasons list ─────────────────────────────────────────────────────── *@
@if (Model.Seasons.Any())
{
    <div style="margin-bottom:var(--gap)">
        <div class="sec-hdr">
            <h2>Seasons</h2>
            <span class="sub">@Model.Seasons.Count() total</span>
            @if (Model.IsCommissioner)
            {
                <span class="right">
                    <a href="/league/@abbr/season/create" style="color:var(--accent);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-family:var(--f-sans);font-size:11px">+ New Season</a>
                </span>
            }
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
            @foreach (var season in Model.Seasons)
            {
                var isSelected = season.Id == Model.SelectedSeasonId;
                <a href="/league/@abbr/season/@season.CardYear"
                   style="display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border:1.5px solid @(isSelected ? "var(--ink)" : "var(--rule-strong)");background:var(--paper);text-decoration:none;color:inherit">
                    <div>
                        <span style="font-family:var(--f-display);font-weight:700;font-size:15px;text-transform:uppercase;letter-spacing:.03em">@season.Name</span>
                        <span style="font-family:var(--f-sans);font-size:10.5px;color:var(--ink-3);margin-left:10px">@season.CardYear cards</span>
                    </div>
                    <span class="pill @(season.Status == "Active" ? "accent" : "")" style="font-size:10px">@season.Status</span>
                </a>
            }
        </div>
    </div>
}
