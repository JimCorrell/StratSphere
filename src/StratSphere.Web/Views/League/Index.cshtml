@model StratSphere.Web.Models.ViewModels.League.LeagueIndexViewModel
@{ ViewData["Title"] = Model.IsAdmin ? "All Leagues" : "My Leagues"; Layout = "_Layout"; }

<div class="sec-hdr" style="margin-bottom:var(--gap)">
    <h2>@(Model.IsAdmin ? "All Leagues" : "My Leagues")</h2>
    @if (Model.IsAdmin && Model.Leagues.Any())
    {
        <span class="right">
            <form action="/league/delete-all" method="post" style="margin:0;display:inline"
                  onsubmit="return confirm('Permanently delete ALL leagues and all related data? This cannot be undone.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn sm danger" style="cursor:pointer">Delete All</button>
            </form>
        </span>
    }
</div>

@if (TempData["Success"] != null)
{
    <div style="background:var(--green-field);color:#fff;padding:9px 16px;margin-bottom:var(--gap);font-family:var(--f-sans);font-size:11px;font-weight:700;letter-spacing:.1em">✓ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div style="background:var(--oxblood);color:#fff;padding:9px 16px;margin-bottom:var(--gap);font-family:var(--f-sans);font-size:11px;font-weight:700;letter-spacing:.1em">⚠ @TempData["Error"]</div>
}

<div class="tenant-picker">

    @foreach (var league in Model.Leagues)
    {
        var mark = league.Abbreviation.Length > 0 ? league.Abbreviation[0].ToString().ToUpper() : "?";
        <a href="/league/@league.Abbreviation.ToLower()" class="tenant-pick @(league.IsArchived ? "" : "")"
           style="text-decoration:none;color:inherit;@(league.IsArchived ? "opacity:.55" : "")">
            <span class="mark">@mark</span>
            <div class="body">
                <b>@league.Name</b>
                @if (league.IsArchived)
                {
                    <div style="color:var(--ink-3)">@league.Abbreviation · <span style="text-transform:uppercase;letter-spacing:.08em;font-size:10px;font-weight:700">Archived</span></div>
                }
                else
                {
                    <div>@league.Abbreviation · @league.Status</div>
                }
                <div style="margin-top:4px">@league.MemberCount member@(league.MemberCount == 1 ? "" : "s")</div>
            </div>
            @if (!string.IsNullOrEmpty(league.Role))
            {
                <span class="pill @(league.Role == "Commissioner" ? "accent" : "")" style="font-size:9px;align-self:flex-start">@league.Role</span>
            }
            @if (Model.IsAdmin && !league.IsArchived)
            {
                <div style="align-self:flex-start;display:flex;gap:6px" onclick="event.preventDefault()">
                    <form action="/league/@league.Abbreviation/archive" method="post" style="margin:0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn sm ghost" style="cursor:pointer">Archive</button>
                    </form>
                    <form action="/league/@league.Abbreviation/delete" method="post" style="margin:0"
                          onsubmit="return confirm('Permanently delete &quot;@league.Name&quot; and all its data?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn sm danger" style="cursor:pointer">Delete</button>
                    </form>
                </div>
            }
            @if (Model.IsAdmin && league.IsArchived)
            {
                <div style="align-self:flex-start" onclick="event.preventDefault()">
                    <form action="/league/@league.Abbreviation/unarchive" method="post" style="margin:0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn sm ghost" style="cursor:pointer">Restore</button>
                    </form>
                </div>
            }
        </a>
    }

    @* New league card *@
    <a href="/league/create" class="tenant-pick new" style="text-decoration:none;color:inherit">
        <span class="mark" style="background:var(--paper-2);color:var(--ink)">+</span>
        <div class="body">
            <b>Start a new league</b>
            <div>Replay, dynasty, draft-and-keep</div>
            <div style="margin-top:4px;color:var(--accent);letter-spacing:.1em;text-transform:uppercase;font-weight:700">Create →</div>
        </div>
    </a>

    @if (!Model.IsAdmin)
    {
        <a href="/league/join" class="tenant-pick new" style="text-decoration:none;color:inherit">
            <span class="mark" style="background:var(--paper-2);color:var(--ink)">↪</span>
            <div class="body">
                <b>Join with code</b>
                <div>Commissioner invitation</div>
                <div style="margin-top:4px;font-family:var(--f-mono);color:var(--ink-3)">Enter league slug</div>
            </div>
        </a>
    }

</div>
