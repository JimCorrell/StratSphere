@model StratSphere.Web.Models.ViewModels.League.NotMemberViewModel
@{ ViewData["Title"] = "Not a Member"; Layout = "_Layout"; }

<div style="max-width:520px;margin:3rem auto;text-align:center">
    <div class="card" style="padding:48px 36px">
        <div style="font-family:var(--f-display);font-size:64px;font-weight:900;text-transform:uppercase;letter-spacing:.04em;color:var(--rule-strong);line-height:1;margin-bottom:20px">⚾</div>
        <div style="font-family:var(--f-display);font-size:32px;font-weight:900;text-transform:uppercase;letter-spacing:-.01em;line-height:1;margin-bottom:10px">
            Not in this league
        </div>
        <p style="font-family:var(--f-serif);font-size:15px;color:var(--ink-2);line-height:1.6;margin:0 0 28px">
            You're not a member of <strong style="font-family:var(--f-display);text-transform:uppercase">@Model.LeagueName</strong>.
            Contact the commissioner if you'd like to join.
        </p>
        <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
            <a href="/league/join" class="btn" style="font-size:13px">Join a league</a>
            <a href="/league" class="btn ghost" style="font-size:13px">My leagues</a>
        </div>
    </div>
</div>
