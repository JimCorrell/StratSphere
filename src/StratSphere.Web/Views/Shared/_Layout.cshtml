<!DOCTYPE html>
<html lang="en" data-theme="paper" id="app-root">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — StratSphere" : "StratSphere")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
    (function(){
        var m = document.cookie.match(/(?:^|;\s*)theme=([^;]+)/);
        if (m) document.documentElement.dataset.theme = m[1];
    })();
    </script>
</head>
<body>

@await Html.PartialAsync("_TopStrip")

@{
    var isCommish = Context.Items[LeagueContextMiddleware.IsCommissionerKey] is bool c && c;
    var hasLeague = Context.Items[LeagueContextMiddleware.LeagueKey] != null;
}

@if (isCommish)
{
    @await Html.PartialAsync("_CommishBar")
}

@if (hasLeague)
{
    @await Html.PartialAsync("_Masthead")
    @await Html.PartialAsync("_PrimaryNav")
}

<div class="page">
    @RenderBody()
</div>

@{
    var footerLeague = Context.Items[LeagueContextMiddleware.LeagueKey] as League;
}
<div class="footer no-sel">
    <span class="brand-tag">★ StratSphere</span>
    @if (footerLeague != null)
    {
        <span>@footerLeague.Name &middot; @footerLeague.Abbreviation</span>
    }
    <span class="spacer"></span>
    <span style="font-size:11px;opacity:.7">Theme:</span>
    <button class="theme-btn" data-theme-val="paper">☀ Paper</button>
    <button class="theme-btn" data-theme-val="dark">☽ Night</button>
    <button class="theme-btn" data-theme-val="scoreboard">⬛ Board</button>
    <span>&copy; @DateTime.Now.Year StratSphere</span>
</div>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
