@{
    var league = Context.Items[LeagueContextMiddleware.LeagueKey] as League;
}

<div class="commish-bar no-sel">
    <span>⚙</span>
    <b>Commissioner Console</b>
    <span>&middot; @(league?.Name ?? "League")</span>
    <div class="commish-actions">
        <a href="/league/@league?.Abbreviation/import" style="font-family:var(--f-display);font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink);text-decoration:none;padding:4px 10px;border:1.5px solid var(--ink);background:transparent">Import SOM</a>
        <button disabled title="Coming soon">Schedule</button>
        <button disabled title="Coming soon">Transactions</button>
        <button disabled title="Coming soon">Park Factors</button>
    </div>
</div>
