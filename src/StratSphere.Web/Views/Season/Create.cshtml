@model StratSphere.Web.Models.ViewModels.Season.CreateSeasonViewModel
@{ ViewData["Title"] = "Create Season"; Layout = "_Layout"; }

<div style="max-width:480px;margin:2rem auto">
    <div style="margin-bottom:12px">
        <a href="/league/@Model.LeagueAbbreviation" style="font-family:var(--f-sans);font-size:12px;color:var(--ink-3);text-decoration:none;letter-spacing:.04em">
            ← Back to league
        </a>
    </div>

    <div class="card" style="padding:32px 32px 28px">
        <div class="eyebrow" style="margin-bottom:8px">Commissioner · Season Setup</div>
        <h1 style="font-family:var(--f-display);font-weight:900;font-size:40px;text-transform:uppercase;letter-spacing:-.01em;line-height:.95;margin:0 0 6px">New Season</h1>
        <p style="font-family:var(--f-serif);font-size:14px;color:var(--ink-2);margin:0 0 24px;line-height:1.5">
            The card year sets which Lahman stats power every player card in this season.
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-controller="Season" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Name" class="form-label">Season Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. 1986 Season" autofocus />
                <span asp-validation-for="Name" style="font-family:var(--f-sans);font-size:11px;color:var(--oxblood)"></span>
            </div>

            <div class="form-group">
                <label asp-for="CardYear" class="form-label">Card Year</label>
                <input asp-for="CardYear" type="number" class="form-control"
                       min="1871" max="2025" placeholder="e.g. 1986"
                       style="font-family:var(--f-mono);font-size:20px;letter-spacing:.04em" />
                <div style="font-family:var(--f-sans);font-size:11px;color:var(--ink-3);margin-top:4px">
                    1871–2025 · determines which historical season is used for player cards
                </div>
                <span asp-validation-for="CardYear" style="font-family:var(--f-sans);font-size:11px;color:var(--oxblood)"></span>
            </div>

            <div style="display:flex;gap:10px;margin-top:8px">
                <button type="submit" class="btn" style="font-size:13px;padding:10px 20px">Create season</button>
                <a href="/league/@Model.LeagueAbbreviation" class="btn ghost" style="font-size:13px;padding:10px 20px">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
