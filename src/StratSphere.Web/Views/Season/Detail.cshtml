@model StratSphere.Web.Models.ViewModels.Season.SeasonDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    Layout = "_Layout";

    var statusColor = Model.Status switch
    {
        "Active"    => "var(--green-field)",
        "Completed" => "var(--ink-3)",
        _           => "var(--mustard)"
    };
    var statusBg = Model.Status switch
    {
        "Active"    => "color-mix(in srgb,var(--green-field) 12%,transparent)",
        "Completed" => "var(--paper-2)",
        _           => "color-mix(in srgb,var(--mustard) 18%,transparent)"
    };
}

@* ── Season header ────────────────────────────────────────────────────────── *@
<div class="card" style="margin-bottom:var(--gap);padding:24px 28px">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:20px;flex-wrap:wrap">
        <div>
            <div class="eyebrow" style="margin-bottom:6px">
                <a href="/league/@Model.LeagueAbbreviation" style="color:var(--ink-3);text-decoration:none">@Model.LeagueName</a>
                <span style="color:var(--rule-strong)"> / </span>Season
            </div>
            <h1 style="font-family:var(--f-display);font-weight:900;font-size:40px;text-transform:uppercase;letter-spacing:-.01em;line-height:.95;margin:0 0 10px">@Model.Name</h1>
            <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
                <span style="font-family:var(--f-mono);font-size:18px;font-weight:700;color:var(--ink-2)">@Model.CardYear</span>
                <span style="font-family:var(--f-sans);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:3px 10px;border:1.5px solid @statusColor;color:@statusColor;background:@statusBg">@Model.Status</span>
            </div>
        </div>

        @if (Model.IsCommissioner)
        {
            <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-start;flex-shrink:0">
                @if (Model.Status == "Setup")
                {
                    <form action="/league/@Model.LeagueAbbreviation/season/@Model.CardYear/activate" method="post" style="margin:0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn"
                                onclick="return confirm('Activate this season? Rosters will be locked and standings will begin tracking.')">
                            Activate Season
                        </button>
                    </form>
                }
                else if (Model.Status == "Active")
                {
                    <form action="/league/@Model.LeagueAbbreviation/season/@Model.CardYear/complete" method="post" style="margin:0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn ghost"
                                onclick="return confirm('Mark this season as completed? This cannot be undone.')">
                            Complete Season
                        </button>
                    </form>
                }
            </div>
        }
    </div>
</div>

@* ── Flash messages ───────────────────────────────────────────────────────── *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="margin-bottom:var(--gap)">✓ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" style="margin-bottom:var(--gap)">⚠ @TempData["Error"]</div>
}

@* ── Teams & rosters table ────────────────────────────────────────────────── *@
<div class="card" style="padding:0;overflow:hidden">
    <div style="padding:16px 20px 12px;border-bottom:1px solid var(--rule);display:flex;align-items:center;justify-content:space-between">
        <div class="eyebrow">Teams &amp; Rosters</div>
        @if (Model.IsCommissioner)
        {
            <a href="/league/@Model.LeagueAbbreviation/team/create" class="btn ghost" style="font-size:11px;padding:5px 12px">+ Add Team</a>
        }
    </div>

    @if (!Model.Teams.Any())
    {
        <div style="padding:48px 24px;text-align:center">
            <div style="font-family:var(--f-display);font-size:28px;font-weight:900;text-transform:uppercase;color:var(--ink-3)">No teams yet</div>
            @if (Model.IsCommissioner)
            {
                <div style="margin-top:16px">
                    <a href="/league/@Model.LeagueAbbreviation/team/create" class="btn" style="font-size:13px">Create first team</a>
                </div>
            }
        </div>
    }
    else
    {
        <table style="width:100%;border-collapse:collapse">
            <thead>
                <tr style="border-bottom:2px solid var(--rule-strong)">
                    <th style="font-family:var(--f-display);font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);padding:10px 20px;text-align:left">Team</th>
                    <th style="font-family:var(--f-display);font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);padding:10px 12px;text-align:left">Manager</th>
                    <th style="font-family:var(--f-display);font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);padding:10px 12px;text-align:right;width:80px">Players</th>
                    <th style="padding:10px 20px;width:100px"></th>
                </tr>
            </thead>
            <tbody>
                @{ int tRank = 0; }
                @foreach (var team in Model.Teams)
                {
                    tRank++;
                    <tr style="border-bottom:1px solid var(--rule);@(tRank % 2 == 0 ? "background:var(--paper-2)" : "")">
                        <td style="padding:12px 20px">
                            <div style="font-family:var(--f-display);font-size:15px;font-weight:700;text-transform:uppercase">
                                @team.City @team.Name
                            </div>
                            <div style="font-family:var(--f-mono);font-size:11px;color:var(--ink-3);margin-top:2px">@team.Abbreviation</div>
                        </td>
                        <td style="padding:12px;font-family:var(--f-sans);font-size:13px">
                            @if (team.IsClaimed)
                            {
                                <span>@team.ManagerName</span>
                            }
                            else
                            {
                                <span style="color:var(--ink-3);font-style:italic">Unclaimed</span>
                            }
                        </td>
                        <td style="padding:12px;text-align:right;font-family:var(--f-mono);font-size:15px;font-weight:@(team.RosterCount > 0 ? "700" : "400");color:@(team.RosterCount > 0 ? "var(--ink)" : "var(--ink-3)")">
                            @team.RosterCount
                        </td>
                        <td style="padding:12px 20px;text-align:right">
                            <a href="/league/@Model.LeagueAbbreviation/season/@Model.CardYear/team/@team.Abbreviation"
                               style="font-family:var(--f-sans);font-size:12px;font-weight:700;letter-spacing:.04em;color:var(--ink);text-decoration:none;text-transform:uppercase">
                                Roster →
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
