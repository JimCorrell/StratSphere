@model StratSphere.Web.Models.ViewModels.Account.RegisterViewModel
@{ ViewData["Title"] = "Create Account"; Layout = null; }
<!DOCTYPE html>
<html lang="en" data-theme="paper">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account — StratSphere</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
    (function(){
        var m = document.cookie.match(/(?:^|;\s*)theme=([^;]+)/);
        if (m) document.documentElement.dataset.theme = m[1];
    })();
    </script>
</head>
<body>

<div class="login-shell">

    <div class="login-art">
        <div class="brand"><span class="star">★</span> StratSphere</div>
        <h1>
            Build<br/>
            your<br/>
            <em>roster.</em>
        </h1>
        <div class="tag">
            Create your free account and step into the front office. Run a league, claim a team, or just obsess over the numbers. No credit card required.
        </div>
        <div class="stats-strip">
            <div class="it"><div class="lbl">Active Leagues</div><div class="val">1,284</div></div>
            <div class="it"><div class="lbl">Sims / Day</div><div class="val">42,180</div></div>
            <div class="it"><div class="lbl">Free to start</div><div class="val" style="color:var(--mustard)">YES</div></div>
        </div>
    </div>

    <div class="login-form">
        <div class="eyebrow">New account · ★</div>
        <h2>Join the<br/>front office.</h2>
        <p class="lead">Create your StratSphere account to start or join a league — replays, dynasties, draft-and-keep, or anything else you can dream up.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:var(--oxblood);color:#fff;padding:10px 14px;margin-bottom:16px;font-family:var(--f-sans);font-size:12px;font-weight:700;letter-spacing:.06em">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <label asp-for="DisplayName">Display Name</label>
            <input asp-for="DisplayName" type="text" placeholder="Your name in leagues" autocomplete="nickname" autofocus />
            <span asp-validation-for="DisplayName" style="font-family:var(--f-sans);font-size:11px;color:var(--oxblood)"></span>

            <label asp-for="Email">Email</label>
            <input asp-for="Email" type="email" placeholder="you@example.com" autocomplete="email" />
            <span asp-validation-for="Email" style="font-family:var(--f-sans);font-size:11px;color:var(--oxblood)"></span>

            <label asp-for="Password">Password</label>
            <input asp-for="Password" type="password" placeholder="Minimum 12 characters" autocomplete="new-password" />
            <span asp-validation-for="Password" style="font-family:var(--f-sans);font-size:11px;color:var(--oxblood)"></span>
            <div style="font-family:var(--f-sans);font-size:10.5px;color:var(--ink-3);margin-top:4px">
                Must include uppercase, lowercase, a number, and a special character.
            </div>

            <label asp-for="ConfirmPassword">Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" style="font-family:var(--f-sans);font-size:11px;color:var(--oxblood)"></span>

            <div style="margin-top:22px;display:flex;gap:10px">
                <button type="submit" class="btn primary" style="flex:1;justify-content:center;cursor:pointer">Create account →</button>
            </div>
        </form>

        <hr class="dash-rule" style="margin:26px 0" />

        <div style="display:flex;gap:10px">
            <a asp-controller="Account" asp-action="Login" class="btn ghost" style="flex:1;justify-content:center;text-decoration:none">Already have an account? Sign in</a>
        </div>

        <div style="margin-top:28px;font-family:var(--f-sans);font-size:10.5px;color:var(--ink-3);letter-spacing:.08em">
            By creating an account you agree to the StratSphere Terms and acknowledge the use of cookies for live sim state.
        </div>
    </div>

</div>

<script src="~/js/site.js" asp-append-version="true"></script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
</body>
</html>
