@model Stratsphere.Web.Models.ViewModels.Team.CreateTeamViewModel
@{ ViewData["Title"] = "Create Team"; Layout = "_Layout"; }

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">
            <h2 class="auth-title">Create Your Team</h2>
            <p class="auth-subtitle">Set up your franchise for this league.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error">
                <span>⚠</span>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="City" class="form-label">City</label>
                <input asp-for="City" class="form-control" placeholder="e.g. Chicago" autofocus />
                <span asp-validation-for="City" class="text-muted" style="font-size:0.8rem"></span>
            </div>

            <div class="form-group">
                <label asp-for="Name" class="form-label">Team Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Cubs" />
                <span asp-validation-for="Name" class="text-muted" style="font-size:0.8rem"></span>
            </div>

            <div class="form-group">
                <label asp-for="Abbreviation" class="form-label">Abbreviation</label>
                <input asp-for="Abbreviation" class="form-control" placeholder="e.g. CHC" maxlength="10" style="text-transform:uppercase;" />
                <span asp-validation-for="Abbreviation" class="text-muted" style="font-size:0.8rem"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg mt-2">
                Create team
            </button>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
