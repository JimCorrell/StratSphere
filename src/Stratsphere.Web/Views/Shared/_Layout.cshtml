<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — Stratsphere" : "Stratsphere")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar">
    <a asp-controller="Home" asp-action="Index" class="navbar-brand">
        <span class="brand-dot"></span>
        Stratsphere
    </a>

    <ul class="navbar-nav">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <li><a asp-controller="Home" asp-action="Dashboard" class="nav-link">Dashboard</a></li>
            <li><a asp-controller="League" asp-action="Index" class="nav-link">My Leagues</a></li>
            <div class="navbar-divider"></div>
            <li><a asp-controller="Account" asp-action="Profile" class="nav-link">@User.Identity.Name?.Split('@')[0]</a></li>
            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-ghost" style="font-size:0.875rem;padding:0.4rem 0.75rem;color:rgba(247,242,232,0.6)">
                        Sign out
                    </button>
                </form>
            </li>
        }
        else
        {
            <li><a asp-controller="Account" asp-action="Login" class="nav-link">Sign in</a></li>
            <li><a asp-controller="Account" asp-action="Register" class="nav-link btn btn-amber" style="margin-left:0.25rem;padding:0.4rem 1rem">Get started</a></li>
        }
    </ul>
</nav>

<div class="page-wrapper">
    @RenderBody()
</div>

<footer class="site-footer">
    &copy; @DateTime.Now.Year Stratsphere &mdash; Built for Strat-O-Matic leagues
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
