@{ ViewData["Title"] = "Home"; Layout = "_Layout"; }

<div style="background: var(--panel); color: var(--cream); padding: 5rem 0 4rem; text-align: center; border-bottom: 3px solid var(--amber);">
    <div class="container">
        <p style="font-size:0.8125rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--amber-light);margin-bottom:1rem;">
            Strat-O-Matic League Management
        </p>
        <h1 style="font-size:3.5rem;color:var(--cream);margin-bottom:1.25rem;line-height:1.1;">
            Your league.<br/>Your stats.<br/>Your history.
        </h1>
        <p style="font-size:1.125rem;color:rgba(226,232,240,0.7);max-width:520px;margin:0 auto 2.5rem;">
            Host Strat-O-Matic simulation leagues with real Lahman player data,
            standings, rosters, and stats — all in one place.
        </p>
        <div class="d-flex gap-2" style="justify-content:center;flex-wrap:wrap;">
            <a asp-controller="Account" asp-action="Register" class="btn btn-amber btn-lg">
                Start a league free
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline btn-lg"
               style="border-color:rgba(226,232,240,0.3);color:var(--cream);">
                Sign in
            </a>
        </div>
    </div>
</div>
