@model Stratsphere.Web.Models.ViewModels.League.LeagueIndexViewModel
@{ ViewData["Title"] = "Dashboard"; Layout = "_Layout"; }

<div class="container" style="padding: 3rem 1rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:2rem;">
        <div>
            <h1 style="color:var(--green-deep); margin:0 0 0.25rem;">Dashboard</h1>
            <p style="color:var(--text-muted); margin:0;">Welcome back, @User.Identity?.Name?.Split('@')[0]</p>
        </div>
        <a asp-controller="League" asp-action="Create" class="btn btn-amber">+ New League</a>
    </div>

    @if (!Model.Leagues.Any())
    {
        <div style="padding:3rem 2rem; background:var(--cream); border:1px solid var(--border); border-radius:8px; text-align:center;">
            <p style="color:var(--text-muted); margin-bottom:1.25rem;">You're not in any leagues yet.</p>
            <a asp-controller="League" asp-action="Create" class="btn btn-amber">Create a league</a>
            <a asp-controller="League" asp-action="Join" class="btn btn-outline" style="margin-left:0.5rem;">Join a league</a>
        </div>
    }
    else
    {
        <div style="display:flex; flex-direction:column; gap:0.75rem;">
            @foreach (var league in Model.Leagues)
            {
                <a href="/league/@league.Slug"
                   style="display:flex; align-items:center; justify-content:space-between; padding:1.25rem 1.5rem;
                          background:var(--cream); border:1px solid var(--border); border-radius:8px;
                          text-decoration:none; color:inherit;">
                    <div>
                        <div style="font-size:1.1rem; font-weight:600; color:var(--green-deep);">@league.Name</div>
                        <div style="font-size:0.8125rem; color:var(--text-muted); margin-top:0.2rem;">
                            @league.MemberCount member@(league.MemberCount == 1 ? "" : "s") &middot; @league.Status
                        </div>
                    </div>
                    <span style="font-size:0.75rem; font-weight:600; letter-spacing:0.06em; text-transform:uppercase;
                                 color:@(league.Role == "Commissioner" ? "var(--amber)" : "var(--text-muted)");">
                        @league.Role
                    </span>
                </a>
            }
        </div>
    }
</div>
