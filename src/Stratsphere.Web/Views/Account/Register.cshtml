@model Stratsphere.Web.Models.ViewModels.Account.RegisterViewModel
@{ ViewData["Title"] = "Create Account"; Layout = "_Layout"; }

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">
            <div class="auth-logo-mark">
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="14" cy="14" r="11" stroke="#c8973a" stroke-width="2"/>
                    <path d="M8 14 Q14 8 20 14 Q14 20 8 14Z" fill="#c8973a" opacity="0.7"/>
                    <circle cx="14" cy="14" r="2.5" fill="#f7f2e8"/>
                </svg>
            </div>
            <h2 class="auth-title">Join Stratsphere</h2>
            <p class="auth-subtitle">Create your free account to start a league</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error">
                <span>⚠</span>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="DisplayName" class="form-label">Display Name</label>
                <input asp-for="DisplayName" class="form-control"
                       placeholder="Your name in leagues" autocomplete="nickname" autofocus />
                <span asp-validation-for="DisplayName" class="text-muted" style="font-size:0.8rem"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email"
                       placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-muted" style="font-size:0.8rem"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" type="password"
                       placeholder="Minimum 8 characters" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-muted" style="font-size:0.8rem"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password"
                       placeholder="••••••••" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-muted" style="font-size:0.8rem"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg mt-2">
                Create account
            </button>
        </form>

        <div class="auth-footer">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">Sign in</a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
