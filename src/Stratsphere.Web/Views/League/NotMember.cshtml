@model Stratsphere.Web.Models.ViewModels.League.NotMemberViewModel
@{ ViewData["Title"] = "Not a Member"; Layout = "_Layout"; }

<div class="container" style="padding: 3rem 1rem; max-width: 560px; margin: 0 auto;">
    <div style="background:var(--cream); border:1px solid var(--border); border-radius:8px; padding:2.5rem; text-align:center;">

        <div style="font-size:2.5rem; margin-bottom:1rem;">⚾</div>

        <h1 style="color:var(--green-deep); font-size:1.5rem; margin:0 0 0.5rem;">You're not in this league</h1>
        <p style="color:var(--text-muted); margin:0 0 2rem;">
            You don't have access to <strong style="color:var(--text);">@Model.LeagueName</strong>.
            Contact the commissioner if you'd like to join.
        </p>

        @* Future: join request / interest form goes here *@

        <div style="display:flex; gap:0.75rem; justify-content:center; flex-wrap:wrap;">
            <a asp-controller="League" asp-action="Join" class="btn btn-primary">Join a league</a>
            <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline">Back to dashboard</a>
        </div>

    </div>
</div>
