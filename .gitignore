## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# NuGet restore cache (created on dotnet restore)
.nuget/
packages/
*.user

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# ── StratSphere-specific ───────────────────────────────────────────────────────

# User secrets & local config overrides — NEVER commit connection strings
appsettings.Local.json
appsettings.*.Local.json
secrets.json
**/Properties/launchSettings.json

# EF Core migrations snapshot is intentionally committed, but exclude
# the designer files that get regenerated on every migration
**/Migrations/*Designer.cs

# Lahman CSV source files — large, downloaded externally, not source code
tools/Stratsphere.DataImport/lahman-csvs/

# ── Claude Code ───────────────────────────────────────────────────────────────

# launch.json is committed (defines how to start the dev server)
# settings.local.json contains local overrides — keep off remote
.claude/settings.local.json

# ── IDE ───────────────────────────────────────────────────────────────────────

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# macOS
.DS_Store
.AppleDouble
.LSOverride
