{
  "hooks": {
    "PostToolUse": [{
      "matcher": "Write|Edit",
      "hooks": [{"type": "command", "command": ".claude/hooks/post-edit.sh", "async": true, "timeout": 30}]
    }],
    "PreToolUse": [{
      "matcher": "Bash",
      "hooks": [{"type": "command", "command": ".claude/hooks/pre-bash.sh"}]
    }],
    "Stop": [{
      "hooks": [{"type": "command", "command": ".claude/hooks/session-end.sh", "async": true, "timeout": 15}]
    }]
  }
}
